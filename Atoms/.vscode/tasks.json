{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Streamlit App",
			"type": "shell",
			"command": "streamlit run streamlit_app.py",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Start Frontend (Vite)",
			"type": "shell",
			"command": "cd frontend && npm install && npm run dev",
			"isBackground": true,
			"group": "build"
		}
	]
}